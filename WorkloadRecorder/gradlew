##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh is
#       noncompliant, but you have some other compliant shell such as ksh or
#       bash, then to run this script, type that shell name before the whole
#       script path, like ksh "path/to/gradlew".
#
#   (2) This is a Bourne-compatible script, so any Bourne-compatible shell
#       (bash, zsh, ksh, etc) will work.
#
#   (3) This script was generated by the Gradle Wrapper generator.
#       Do not modify it directly.
#
##############################################################################

# Resolve links: $0 may be a link
APP_HOME=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)

# Need this for daisy-chained symlinks.
while
  APP_HOME=${APP_HOME%/}
  target=$(readlink "$APP_HOME")
  if
    [ -z "$target" ]
  then
    break
  fi
  cd -- "$(dirname -- "$APP_HOME")" || exit
  APP_HOME=$(cd -- "$(dirname -- "$target")" && pwd)/$(basename -- "$target")
do
  continue
done

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD=maximum

warn () {
    echo "$*"
} >&2

die () {
    echo
    echo "$*"
    echo
    exit 1
} >&2

# OS specific support (must be 'true' or 'false').
cygwin=false
msys=false
darwin=false
nonstop=false
case "$(uname)" in
  CYGWIN* )
    cygwin=true
    ;;
  Darwin* )
    darwin=true
    ;;
  MINGW* )
    msys=true
    ;;
  NONSTOP* )
    nonstop=true
    ;;
esac

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD="$JAVA_HOME/jre/sh/java"
    else
        JAVACMD="$JAVA_HOME/bin/java"
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
else
    JAVACMD="java"
    command -v java >/dev/null 2>&1 || die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH.

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
fi

# Increase the maximum file descriptors if we can.
if [ "$cygwin" = "false" -a "$darwin" = "false" -a "$nonstop" = "false" ] ; then
    if [ -z "$MAX_FD" ] || [ "$MAX_FD" = "maximum" ] ; then
        MAX_FD=$(ulimit -H -n 2>/dev/null || echo -1)
    fi
    if [ "$MAX_FD" != -1 ] ; then
        ulimit -n "$MAX_FD"
    fi
fi

# Collect arguments
#
# GRADLE_APP_NAME allows the app name printed in the usage info to be overridden
# APP_ARGS contains arguments to the application (the main class)
# DEFAULT_JVM_OPTS are JVM options that can be overridden
# JAVA_OPTS are environment variables which are applied first
# GRADLE_OPTS are environment variables which are applied second
APP_NAME=${GRADLE_APP_NAME:-Gradle}
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'
APP_ARGS=

while true ; do
    case "$1" in
        --no-daemon )
            APP_ARGS="$APP_ARGS $1"
            ;;
        *)
            break
            ;;
    esac
    shift
done

# Split up the JVM_OPTS And GRADLE_OPTS into an array,
# to properly handle spaces.
JVM_OPTS=
CLASSPATH_ARG=

# Collect all arguments for the java command, following the shell quoting and substitution rules
eval set -- "$DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS -Dorg.gradle.appname=$APP_NAME -classpath \"$CLASSPATH\" org.gradle.wrapper.GradleWrapperMain $APP_ARGS $*"

# Determine the main class name, depending on which wrapper mode we're in
WRAPPER_JAR="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"
MAIN_CLASS=org.gradle.wrapper.GradleWrapperMain
if [ -e "$APP_HOME/gradle/wrapper/gradle-wrapper-main-class.txt" ] ; then
  MAIN_CLASS=$(cat "$APP_HOME/gradle/wrapper/gradle-wrapper-main-class.txt" 2>/dev/null)
fi

exec "$JAVACMD" -jar "$WRAPPER_JAR" "$@"
